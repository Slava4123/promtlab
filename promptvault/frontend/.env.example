# Frontend env vars — Vite читает из этого файла при dev/build.
# Скопировать как .env.local (в gitignore) для dev override, либо
# пробрасывать как build-args в Dockerfile.frontend-nginx для prod.

# Backend API для dev proxy (vite.config.ts server.proxy target).
VITE_API_URL=http://localhost:8080

# Sentry (GlitchTip) — error tracking.
# В dev обычно false (шум не нужен). В prod ставится через build-args в CI.
VITE_SENTRY_ENABLED=false
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=dev
VITE_SENTRY_TRACES_SAMPLE_RATE=0.0
