            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.2},
            {"color": "green", "value": 0.5}
          ]},
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": {"h": 5, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name", "justifyMode": "auto", "orientation": "auto"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "instance:node_memory:available_ratio", "legendFormat": "Свободно RAM", "refId": "A"}
      ],
      "title": "Свободная RAM (доля)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.1},
            {"color": "green", "value": 0.3}
          ]},
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": {"h": 5, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name", "justifyMode": "auto", "orientation": "auto"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "min(instance:node_filesystem:available_ratio{mountpoint=\"/\"})", "legendFormat": "Свободно на /", "refId": "A"}
      ],
      "title": "Свободно на /",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "none"
        }
      },
      "gridPos": {"h": 5, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "value_and_name", "justifyMode": "auto", "orientation": "auto"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "node_load1", "legendFormat": "1 мин", "refId": "A"}
      ],
      "title": "Средняя нагрузка (load1)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 20, "stacking": {"mode": "none"}},
          "unit": "bytes"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "id": 4,
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "container:memory:usage_bytes", "legendFormat": "{{name}}", "refId": "A"}
      ],
      "title": "Память по контейнерам",
      "description": "Working set (исключая page cache) — то, что kernel учитывает при OOM kill. cAdvisor v0.54+ корректно экспортирует с label name на Docker overlayfs storage driver.",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 20, "stacking": {"mode": "none"}},
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "id": 5,
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "container:cpu:usage_rate5m", "legendFormat": "{{name}}", "refId": "A"}
      ],
      "title": "CPU по контейнерам (5 мин rate)",
      "description": "rate(container_cpu_usage_seconds_total) — доля одного ядра, используемая контейнером (1.0 = 100% одного CPU).",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 30, "stacking": {"mode": "normal"}},
          "unit": "Bps"
        }
      },
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 13},
      "id": 6,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.+|veth.+|br-.+\"}[5m])", "legendFormat": "rx {{device}}", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.+|veth.+|br-.+\"}[5m])", "legendFormat": "tx {{device}}", "refId": "B"}
      ],
      "title": "Сеть (host)",
      "type": "timeseries"
    }
