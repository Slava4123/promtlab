FROM node:22-alpine AS builder
WORKDIR /app
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci
COPY frontend/ .
RUN npm run build

FROM jonasal/nginx-certbot:5-alpine
ARG DOMAIN
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx/nginx.conf /tmp/nginx.conf.template
RUN envsubst '${DOMAIN}' < /tmp/nginx.conf.template > /etc/nginx/user_conf.d/default.conf && rm /tmp/nginx.conf.template
