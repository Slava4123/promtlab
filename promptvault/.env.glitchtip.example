# GlitchTip self-hosted — переменные окружения
#
# Скопировать как .env.glitchtip и заполнить реальными значениями.
# НЕ коммитить .env.glitchtip в git (покрыт .gitignore).
#
# Docs: https://glitchtip.com/documentation/install

# Обязательно: random secret для Django сессий.
# Сгенерировать: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHARS

# Managed PostgreSQL от Timeweb Cloud — отдельная БД glitchtip на том же инстансе.
# БД нужно создать вручную в Timeweb Cloud console (Managed PostgreSQL → Databases → Add → glitchtip).
# sslrootcert путь внутри контейнера — смонтирован bind mount'ом из ./ca.crt
DATABASE_URL=postgres://gen_user:CHANGE_ME_DB_PASSWORD@fdf27c65a5c6ba390823dd0e.twc1.net:5432/glitchtip?sslmode=verify-full&sslrootcert=/app/ca.crt

# Valkey (Redis-compatible) — внутренний контейнер, не требует паролей.
VALKEY_URL=redis://glitchtip-valkey:6379/0

# Публичный URL для доступа к UI (через nginx reverse proxy).
# Должен совпадать с server_name в nginx vhost и значением SENTRY_DOMAIN в .env.prod.
GLITCHTIP_DOMAIN=https://sentry.promtlabs.ru

# Email для уведомлений. Можно переиспользовать SMTP credentials из .env.prod.
DEFAULT_FROM_EMAIL=noreply@promtlabs.ru
EMAIL_URL=smtp+tls://SMTP_USER:SMTP_PASSWORD@smtp.example.com:465

# Production tuning — комфортные значения, можно повышать при upgrade VPS.
CELERY_WORKER_CONCURRENCY=2
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

# Безопасность — отключаем публичную регистрацию и создание организаций.
# Superuser создаётся через: docker compose exec glitchtip-web ./manage.py createsuperuser
ENABLE_USER_REGISTRATION=false
ENABLE_ORGANIZATION_CREATION=false

# Retention событий — 90 дней. При желании уменьшить если Postgres разрастается.
GLITCHTIP_MAX_EVENT_LIFE_DAYS=90

# Domain для CSRF проверки (без https://, только hostname).
CSRF_TRUSTED_ORIGINS=https://sentry.promtlabs.ru
