# Server
SERVER_PORT=8080
SERVER_ENVIRONMENT=development
SERVER_ALLOWED_ORIGINS=http://localhost:5173
SERVER_FRONTEND_URL=http://localhost:5173

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=promptvault
DATABASE_SSLMODE=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5

# JWT
JWT_SECRET=change-me-to-random-64-chars
JWT_ACCESS_DURATION=15m
JWT_REFRESH_DURATION=168h

# OAuth (optional)
OAUTH_CALLBACK_BASE=http://localhost:8080
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_YANDEX_CLIENT_ID=
OAUTH_YANDEX_CLIENT_SECRET=

# SMTP (optional, for email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Payment (T-Bank)
# PAYMENT_ENABLED=true в prod — все T-Bank ключи ниже обязательны,
# иначе сервер fail-fast при старте (config/payment.go Validate).
# В prod: PAYMENT_TBANK_BASE_URL=https://securepay.tinkoff.ru/v2 (боевой терминал).
# В sandbox: https://rest-api-test.tinkoff.ru/v2.
PAYMENT_ENABLED=false
PAYMENT_TBANK_TERMINAL_KEY=
PAYMENT_TBANK_PASSWORD=
PAYMENT_TBANK_BASE_URL=https://securepay.tinkoff.ru/v2
# PAYMENT_WEBHOOK_BASE_URL — публичный URL backend'а, на который T-Bank шлёт webhook.
# Prod: https://api.promtlabs.ru. Dev: используйте tunnel (ngrok/cloudflared):
#   ngrok http 8080  →  https://xxxx.ngrok-free.app
# Без этого webhook'и не дойдут и оплата не активирует подписку.
PAYMENT_WEBHOOK_BASE_URL=
PAYMENT_SUCCESS_URL=/settings?payment=success
PAYMENT_FAIL_URL=/settings?payment=failure
# 54-ФЗ Receipt — фискальный чек через подключённую онлайн-кассу T-Bank.
# Включать только после подключения «Чеков Т-Бизнеса» / «Кассы» / CloudKassir.
# Taxation: usn_income | usn_income_outcome | osn | patent | esn
PAYMENT_RECEIPT_ENABLED=false
PAYMENT_TAXATION=usn_income

# Рекуррент — Recurrent=Y + CustomerKey в Init для автопродления. В prod всегда true.
# Отключать только временно для прохождения теста 1 T-Bank (их проверка падает на Recurrent=Y).
PAYMENT_RECURRENT_ENABLED=true

# IP allowlist T-Bank webhook — defence-in-depth поверх SHA-256 подписи.
# Публичные IP T-Bank (на 2026): 212.233.80.7, 91.218.132.2, 91.194.226.0/23
# Формат: через запятую. Пустое значение — middleware no-op (dev/pre-prod).
# WebhookTrustXFF=true в prod за nginx (он ставит X-Forwarded-For), false при прямом подключении.
PAYMENT_WEBHOOK_ALLOWED_IPS=
PAYMENT_WEBHOOK_TRUST_XFF=false

# Sentry (GlitchTip self-hosted) — error tracking
# Enabled=false по умолчанию для gradual rollout. Включить через SENTRY_ENABLED=true в .env.prod.
# DSN получить из GlitchTip UI: Settings → Projects → promptvault-backend → Client Keys
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_DEBUG=false

# Sentry subdomain — используется в docker-compose.prod.yml для nginx vhost и CERTBOT_DOMAINS
SENTRY_DOMAIN=sentry.promtlabs.ru

# Analytics (Phase 14)
# ExperimentalInsights=false — 4 неготовых Smart Insight типа
# (most_edited, possible_duplicates, orphan_tags, empty_collections) скрыты
# до реализации (follow-up тикет M8). 3 рабочих типа
# (unused_prompts, trending, declining) возвращаются всегда на Max.
ANALYTICS_EXPERIMENTAL_INSIGHTS=false

# Postgres container (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=promptvault
